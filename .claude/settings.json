{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(git push|git push --force|git reset --hard|git clean -f|rm -rf /|> /dev/)'; then echo 'BLOCKED: Dangerous command detected'; exit 1; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status --short)",
      "Bash(git diff)",
      "Bash(git diff --stat)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(mkdir *)",
      "Bash(./gradlew projects)",
      "Bash(./gradlew :app:assembleDebug)",
      "Bash(./gradlew test)",
      "Bash(./gradlew *)",
      "Bash(which *)",
      "Bash(echo *)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push --force)",
      "Bash(git reset --hard)",
      "Bash(rm -rf /)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "sandbox": {
    "enabled": false
  }
}
